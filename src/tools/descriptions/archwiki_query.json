{
  "name": "archwiki_query",
  "display_name": "查询 ArchWiki",
  "description": "Search or read ArchWiki pages.",
  "parameters": {
    "type": "object",
    "properties": {
      "query": {
        "type": "string"
      },
      "title": {
        "type": "string"
      },
      "mode": {
        "type": "string",
        "enum": [
          "auto",
          "search",
          "page"
        ]
      }
    }
  },
  "permission": "readonly",
  "always_loaded": false,
  "load_policy": "summary",
  "groups": [
    "arch"
  ]
}
