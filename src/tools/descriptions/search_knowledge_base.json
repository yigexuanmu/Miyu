{
  "name": "search_knowledge_base",
  "display_name": "搜索知识库",
  "description": "Search the local knowledge base content. Returns file paths and original text snippets. Use read_knowledge_base_file if snippets are insufficient. ",
  "parameters": {
    "type": "object",
    "properties": {
      "query": {
        "type": "string",
        "description": "Search keywords or user question."
      },
      "max_results": {
        "type": "integer",
        "description": "Optional result limit."
      }
    },
    "required": [
      "query"
    ]
  },
  "permission": "readonly",
  "always_loaded": false,
  "load_policy": "summary",
  "groups": [
    "knowledge"
  ]
}
