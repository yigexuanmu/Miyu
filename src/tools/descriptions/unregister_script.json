{
  "name": "unregister_script",
  "display_name": "注销脚本",
  "description": "注销用户脚本。保留文件时会记录为禁用，防止被自动扫描重新注册。",
  "parameters": {
    "type": "object",
    "properties": {
      "id": {
        "type": "string",
        "description": "要注销的脚本 id。"
      },
      "delete_file": {
        "type": "boolean",
        "description": "若为 true，同时从磁盘删除脚本文件。仅影响 scripts 目录内的文件。"
      }
    },
    "required": [
      "id"
    ]
  },
  "permission": "writes",
  "always_loaded": false,
  "load_policy": "group",
  "groups": [
    "scripting"
  ]
}
