{
  "name": "web_fetch",
  "display_name": "读取网页",
  "description": "Fetch a URL and return markdown, text, or html.Does not search the web.",
  "parameters": {
    "type": "object",
    "properties": {
      "url": {
        "type": "string",
        "description": "Fully-qualified http or https URL."
      },
      "format": {
        "type": "string",
        "enum": [
          "markdown",
          "text",
          "html"
        ]
      },
      "timeout": {
        "type": "integer",
        "description": "Timeout seconds, max 120."
      },
      "max_chars": {
        "type": "integer",
        "description": "Maximum characters to return. Defaults to 40000, max 200000."
      }
    },
    "required": [
      "url"
    ]
  },
  "permission": "readonly",
  "always_loaded": true,
  "load_policy": "summary",
  "groups": [
    "web"
  ]
}
