{
  "name": "protondb_query",
  "display_name": "查询 ProtonDB",
  "description": "查询 ProtonDB 上最新的 Linux 游戏兼容性评级和用户评论。支持 Steam App ID或游戏名称。如果被问到的游戏在steam上，优先查询 ProtonDB。",
  "parameters": {
    "type": "object",
    "properties": {
      "query": {
        "type": "string"
      },
      "max_reports": {
        "type": "integer"
      }
    }
  },
  "permission": "readonly",
  "always_loaded": false,
  "load_policy": "group",
  "groups": [
    "gaming"
  ]
}
