#!/usr/bin/env bash
# 显示名称：查询进程占用
# 描述：查询进程的CPU和内存占用，还能列出最高资源占用排名。
# description: Rank all processes, or list CPU/memory usage for one app.

set -euo pipefail

readonly SCRIPT_NAME="procusage"
readonly CMD_MAX_LEN=120

usage() {
  if is_zh_locale; then
    cat <<'EOF'
procusage - 查看进程 CPU 和内存占用

  procusage rank [cpu|mem] [N]   全局排名，默认 CPU 前 10
  procusage <软件名>              列出该软件的进程占用
  procusage -h|--help            显示帮助
EOF
  else
    cat <<'EOF'
procusage - view process CPU and memory usage

  procusage rank [cpu|mem] [N]   global ranking, default CPU top 10
  procusage <app>                list process usage for an app
  procusage -h|--help            show help
EOF
  fi
}

err() { printf 'error: %s\n' "$*" >&2; }
die() { err "$*"; exit 1; }

is_zh_locale() {
  local locale_value="${LC_ALL:-${LC_MESSAGES:-${LANG:-}}}"
  [[ "${locale_value,,}" == zh* ]]
}

is_positive_int() {
  [[ "${1:-}" =~ ^[1-9][0-9]*$ ]]
}

json_string_value() {
  local input="$1" key="$2" pattern
  pattern="\"$key\"[[:space:]]*:[[:space:]]*\"([^\"]*)\""
  [[ "$input" =~ $pattern ]] && printf '%s' "${BASH_REMATCH[1]}"
}

json_number_value() {
  local input="$1" key="$2" pattern
  pattern="\"$key\"[[:space:]]*:[[:space:]]*([0-9]+)"
  [[ "$input" =~ $pattern ]] && printf '%s' "${BASH_REMATCH[1]}"
}

json_first_arg() {
  local input="$1" pattern
  pattern='"args"[[:space:]]*:[[:space:]]*\[[[:space:]]*"([^"]*)"'
  [[ "$input" =~ $pattern ]] && printf '%s' "${BASH_REMATCH[1]}"
}

argv_from_stdin() {
  local input="$1" mode app sort n value
  input="$(trim "$input")"
  [[ -n "$input" ]] || return 1

  if [[ "$input" != *'{'* && "$input" != *'['* && "$input" != *':'* ]]; then
    printf '%s\n' $input
    return 0
  fi

  mode="$(json_string_value "$input" mode)"
  [[ -z "$mode" ]] && mode="$(json_string_value "$input" command)"
  sort="$(json_string_value "$input" sort)"
  n="$(json_number_value "$input" n)"
  [[ -z "$n" ]] && n="$(json_number_value "$input" count)"
  [[ -z "$n" ]] && n="$(json_number_value "$input" limit)"

  for key in app app_name appName application name software program process process_name processName query target; do
    value="$(json_string_value "$input" "$key")"
    [[ -n "$value" ]] && { app="$value"; break; }
  done

  value="$(json_first_arg "$input")"
  if [[ -n "$value" ]]; then
    printf '%s\n' "$value"
    return 0
  fi

  if [[ "$mode" == "rank" ]]; then
    printf '%s\n' rank
    [[ -n "$sort" ]] && printf '%s\n' "$sort"
    [[ -n "$n" ]] && printf '%s\n' "$n"
    return 0
  fi

  [[ -n "${app:-}" ]] && { printf '%s\n' "$app"; return 0; }
  return 1
}

trim() {
  local value="${1:-}"
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  printf '%s' "$value"
}

strip_quotes() {
  local value="${1:-}"
  if [[ "$value" == '"'*'"' && ${#value} -ge 2 ]]; then
    value="${value:1:${#value}-2}"
  elif [[ "$value" == "'"*"'" && ${#value} -ge 2 ]]; then
    value="${value:1:${#value}-2}"
  fi
  printf '%s' "$value"
}

same_token() {
  [[ "${1,,}" == "${2,,}" ]]
}

contains_token() {
  [[ "${1,,}" == *"${2,,}"* ]]
}

desktop_dirs() {
  printf '%s\n' \
    "$HOME/.local/share/applications" \
    "$HOME/.local/share/flatpak/exports/share/applications" \
    "/usr/local/share/applications" \
    "/usr/share/applications" \
    "/var/lib/flatpak/exports/share/applications"
}

desktop_id() {
  local path="${1##*/}"
  printf '%s' "${path%.desktop}"
}

first_exec_word() {
  local exec_line="${1:-}" token
  exec_line="${exec_line//%[fFuUdDnNickvm]/}"
  exec_line="$(trim "$exec_line")"
  [[ -n "$exec_line" ]] || return 1

  if [[ "$exec_line" == '"'* ]]; then
    token="${exec_line#\"}"
    token="${token%%\"*}"
  elif [[ "$exec_line" == "'"* ]]; then
    token="${exec_line#\'}"
    token="${token%%\'*}"
  else
    token="${exec_line%%[[:space:]]*}"
  fi

  token="$(strip_quotes "$token")"
  [[ -n "$token" ]] || return 1
  printf '%s' "$token"
}

resolve_exec_path() {
  local exec_word="$1" resolved

  if [[ "$exec_word" == */* ]]; then
    readlink -f "$exec_word" 2>/dev/null || printf '%s' "$exec_word"
    return 0
  fi

  if resolved="$(command -v -- "$exec_word" 2>/dev/null)"; then
    readlink -f "$resolved" 2>/dev/null || printf '%s' "$resolved"
    return 0
  fi

  printf '%s' "$exec_word"
}

resolve_wrapper_exec_path() {
  local path="$1" depth="${2:-0}"
  local line token resolved nested base dir sibling

  (( depth < 5 )) || return 1
  [[ -r "$path" && -f "$path" ]] || return 1
  IFS= read -r line < "$path" || return 1
  [[ "$line" == '#!'* ]] || return 1

  while IFS= read -r line; do
    line="$(trim "$line")"
    [[ "$line" == exec[[:space:]]/* ]] || continue

    token="${line#exec }"
    token="${token%%[[:space:]]*}"
    token="$(strip_quotes "$token")"
    [[ -n "$token" ]] || continue

    resolved="$(resolve_exec_path "$token")"
    nested="$(resolve_wrapper_exec_path "$resolved" "$((depth + 1))" 2>/dev/null || true)"
    printf '%s' "${nested:-$resolved}"
    return 0
  done < "$path"

  base="${path##*/}"
  dir="${path%/*}"
  sibling="$dir/../$base"
  if [[ "$dir" == */bin && -x "$sibling" ]]; then
    readlink -f "$sibling" 2>/dev/null || printf '%s' "$sibling"
    return 0
  fi

  return 1
}

parse_desktop() {
  local file="$1"
  local line key value name="" name_l10n="" exec_line="" tryexec="" wmclass=""

  [[ -r "$file" ]] || return 1
  while IFS= read -r line; do
    [[ "$line" == *=* ]] || continue
    key="${line%%=*}"
    value="${line#*=}"
    case "$key" in
      Name) [[ -z "$name" ]] && name="$value" ;;
      Name\[*\]) [[ -z "$name_l10n" ]] && name_l10n="$value" ;;
      Exec) [[ -z "$exec_line" ]] && exec_line="$value" ;;
      TryExec) [[ -z "$tryexec" ]] && tryexec="$value" ;;
      StartupWMClass) [[ -z "$wmclass" ]] && wmclass="$value" ;;
    esac
  done < "$file"

  [[ -n "$exec_line" ]] || return 1
  printf '%s\t%s\t%s\t%s\t%s\n' "$exec_line" "$tryexec" "$name" "$name_l10n" "$wmclass"
}

desktop_score() {
  local file="$1" query="$2" parsed="$3"
  local id exec_line tryexec name name_l10n wmclass exec_word exec_base score=0

  id="$(desktop_id "$file")"
  IFS=$'\t' read -r exec_line tryexec name name_l10n wmclass <<< "$parsed"
  exec_word="$(first_exec_word "$exec_line" 2>/dev/null || true)"
  exec_base="${exec_word##*/}"

  same_token "$id" "$query" && ((score += 150))
  [[ -n "$name" ]] && same_token "$name" "$query" && ((score += 140))
  [[ -n "$name_l10n" ]] && same_token "$name_l10n" "$query" && ((score += 140))
  [[ -n "$exec_base" ]] && same_token "$exec_base" "$query" && ((score += 150))
  [[ -n "$tryexec" ]] && same_token "${tryexec##*/}" "$query" && ((score += 130))
  [[ -n "$wmclass" ]] && same_token "$wmclass" "$query" && ((score += 120))

  if (( ${#query} >= 4 )); then
    contains_token "$id" "$query" && ((score += 25))
    [[ -n "$name" ]] && contains_token "$name" "$query" && ((score += 30))
    [[ -n "$name_l10n" ]] && contains_token "$name_l10n" "$query" && ((score += 30))
    [[ -n "$exec_base" ]] && contains_token "$exec_base" "$query" && ((score += 25))
  fi

  printf '%s' "$score"
}

desktop_result() {
  local file="$1" parsed="$2"
  local exec_line tryexec name name_l10n wmclass exec_word resolved wrapper names

  IFS=$'\t' read -r exec_line tryexec name name_l10n wmclass <<< "$parsed"
  exec_word="$(first_exec_word "$exec_line" 2>/dev/null || true)"
  [[ -n "$exec_word" ]] || return 1

  resolved="$(resolve_exec_path "$exec_word")"
  wrapper="$(resolve_wrapper_exec_path "$resolved" 2>/dev/null || true)"
  [[ -n "$wrapper" ]] && resolved="$wrapper"

  names="$name"
  [[ -n "$name_l10n" ]] && names+="|$name_l10n"
  [[ -n "$wmclass" ]] && names+="|$wmclass"
  names+="|$(desktop_id "$file")|${exec_word##*/}|${resolved##*/}"

  printf '%s\t%s\n' "$resolved" "$names"
}

desktop_by_exact_id() {
  local query="$1" dir file parsed

  while IFS= read -r dir; do
    [[ -d "$dir" ]] || continue
    for file in "$dir/$query.desktop" "$dir/${query,,}.desktop"; do
      [[ -f "$file" ]] || continue
      parsed="$(parse_desktop "$file" 2>/dev/null || true)"
      [[ -n "$parsed" ]] || continue
      desktop_result "$file" "$parsed"
      return 0
    done
  done < <(desktop_dirs)

  return 1
}

desktop_by_scan() {
  local query="$1" dir file parsed score
  local best_score=0 best_file="" best_parsed=""

  shopt -s nullglob
  while IFS= read -r dir; do
    [[ -d "$dir" ]] || continue
    for file in "$dir"/*.desktop; do
      parsed="$(parse_desktop "$file" 2>/dev/null || true)"
      [[ -n "$parsed" ]] || continue
      score="$(desktop_score "$file" "$query" "$parsed")"
      (( score > best_score )) || continue

      best_score="$score"
      best_file="$file"
      best_parsed="$parsed"
    done
  done < <(desktop_dirs)
  shopt -u nullglob

  (( best_score >= 80 )) || return 1
  desktop_result "$best_file" "$best_parsed"
}

command_target() {
  local query="$1" resolved wrapper

  resolved="$(resolve_exec_path "$query")"
  [[ "$resolved" != "$query" || "$query" == */* ]] || return 1

  wrapper="$(resolve_wrapper_exec_path "$resolved" 2>/dev/null || true)"
  [[ -n "$wrapper" ]] && resolved="$wrapper"

  printf '%s\t%s\n' "$resolved" "${query##*/}|${resolved##*/}"
}

find_app_target() {
  local query="$1"

  desktop_by_exact_id "$query" && return 0
  command_target "$query" && return 0
  desktop_by_scan "$query" && return 0
  return 1
}

short_cmd() {
  local cmd="$1"
  if (( ${#cmd} > CMD_MAX_LEN )); then
    printf '%s...' "${cmd:0:CMD_MAX_LEN-3}"
  else
    printf '%s' "$cmd"
  fi
}

emit_row() {
  local cpu="$1" mem_pct="$2" rss_kb="$3" pid="$4" ppid="$5" user="$6" comm="$7" args="$8"
  local argv0 argv0_base

  [[ -n "$pid" && -n "$args" ]] || return 0
  [[ "$pid" == "$$" || "$pid" == "$PPID" ]] && return 0
  [[ "$args" == *"$SCRIPT_NAME"* ]] && return 0

  argv0="${args%%[[:space:]]*}"
  argv0_base="${argv0##*/}"
  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n' \
    "$cpu" "$mem_pct" "$rss_kb" "$pid" "$ppid" "$user" "$comm" "$argv0_base" "$(short_cmd "$args")"
}

collect_all_rows() {
  local pid ppid user cpu mem_pct rss_kb comm args
  local -a ps_args=(
    ww
    -eo
    pid=,ppid=,user=,pcpu=,pmem=,rss=,comm=,args=
    --no-headers
  )

  while read -r pid ppid user cpu mem_pct rss_kb comm args; do
    emit_row "$cpu" "$mem_pct" "$rss_kb" "$pid" "$ppid" "$user" "$comm" "$args"
  done < <(ps "${ps_args[@]}")
}

collect_app_rows() {
  local query="$1" expected_exec="$2" names="$3" expected_base="$4"
  local pid ppid user cpu mem_pct rss_kb comm args argv0 argv0_base
  local exe_base exe_path matched name row
  local -a ps_args=(
    ww
    -eo
    pid=,ppid=,user=,pcpu=,pmem=,rss=,comm=,args=
    --no-headers
  )
  local -a name_parts=()

  IFS='|' read -r -a name_parts <<< "$names"

  while read -r pid ppid user cpu mem_pct rss_kb comm args; do
    [[ -n "$pid" && -n "$args" ]] || continue
    [[ "$pid" == "$$" || "$pid" == "$PPID" ]] && continue
    [[ "$args" == *"$SCRIPT_NAME"* ]] && continue

    argv0="${args%%[[:space:]]*}"
    argv0_base="${argv0##*/}"
    matched=0

    if [[ -n "$expected_exec" ]]; then
      exe_base="${expected_exec##*/}"
      exe_path="$(readlink -f "/proc/$pid/exe" 2>/dev/null || true)"
      if [[ "$exe_path" == "$expected_exec" ]]; then
        matched=1
      fi
    fi

    if [[ -n "$expected_base" ]]; then
      same_token "$comm" "$expected_base" && matched=1
      same_token "$argv0_base" "$expected_base" && matched=1
    fi

    same_token "$comm" "$query" && matched=1
    same_token "$argv0_base" "$query" && matched=1

    for name in "${name_parts[@]}"; do
      name="$(trim "$name")"
      [[ -n "$name" ]] || continue
      same_token "$comm" "$name" && matched=1
      same_token "$argv0_base" "$name" && matched=1
    done

    if (( matched == 0 && ${#query} >= 4 )) && [[ -z "$expected_base" ]]; then
      contains_token "$comm" "$query" && matched=1
      contains_token "$argv0_base" "$query" && matched=1
      contains_token "$args" "$query" && matched=1
    fi

    (( matched == 1 )) || continue

    row="$(emit_row "$cpu" "$mem_pct" "$rss_kb" "$pid" "$ppid" "$user" "$comm" "$args")"
    [[ -n "$row" ]] && printf '%s\n' "$row"
  done < <(ps "${ps_args[@]}")
}

sort_rows() {
  local sort_by="$1"
  case "$sort_by" in
    mem|memory) sort -t $'\t' -k3,3nr -k1,1nr ;;
    cpu|'') sort -t $'\t' -k1,1nr -k3,3nr ;;
    *) die "sort must be cpu or mem" ;;
  esac
}

print_rank_rows() {
  local sort_by="$1" limit="$2" rows rows_to_print

  rows="$(collect_all_rows | sort_rows "$sort_by")"
  [[ -n "$rows" ]] || die "no process found"
  rows_to_print="$(printf '%s\n' "$rows" | awk -v n="$limit" 'NR <= n')"

  printf '%-4s %-8s %-7s %-10s %-16s %s\n' "RANK" "PID" "CPU%" "MEM_MB" "NAME" "COMMAND"
  printf '%s\n' "$rows_to_print" | awk -F '\t' '
    NF { printf "%-4d %-8s %-7.1f %-10.1f %-16s %s\n", NR, $4, $1, $3 / 1024, $7, $9 }
  '
}

print_app_rows() {
  local app="$1" expected_exec="$2" names="$3" expected_base="$4" rows total_cpu total_mem_mb count

  rows="$(collect_app_rows "$app" "$expected_exec" "$names" "$expected_base" | sort_rows cpu)"
  [[ -n "$rows" ]] || die "no matching process found for '$app'"

  total_cpu="$(printf '%s\n' "$rows" | awk -F '\t' '{ s += $1 } END { printf "%.1f", s }')"
  total_mem_mb="$(printf '%s\n' "$rows" | awk -F '\t' '{ s += $3 } END { printf "%.1f", s / 1024 }')"
  count="$(printf '%s\n' "$rows" | awk 'NF { c++ } END { print c + 0 }')"

  printf '%-8s %-7s %-10s %-16s %s\n' "PID" "CPU%" "MEM_MB" "NAME" "COMMAND"
  printf '%s\n' "$rows" | awk -F '\t' '
    NF { printf "%-8s %-7.1f %-10.1f %-16s %s\n", $4, $1, $3 / 1024, $7, $9 }
  '
  printf '%-8s %-7s %-10s %-16s %s\n' "TOTAL" "$total_cpu" "$total_mem_mb" "$count" "processes"
}

parse_args() {
  mode=""
  app=""
  sort_by="cpu"
  limit=10

  if [[ $# -eq 0 && ! -t 0 ]]; then
    mapfile -t stdin_args < <(argv_from_stdin "$(cat)" 2>/dev/null || true)
    if ((${#stdin_args[@]} > 0)); then
      set -- "${stdin_args[@]}"
    fi
  fi

  case "${1:-}" in
    ''|-h|--help|help)
      usage
      exit 0
      ;;
    rank)
      mode="rank"
      if [[ -z "${2:-}" ]]; then
        :
      elif [[ "${2:-}" == "cpu" || "${2:-}" == "mem" || "${2:-}" == "memory" ]]; then
        sort_by="$2"
        [[ -n "${3:-}" ]] && limit="$3"
      elif is_positive_int "${2:-}"; then
        limit="$2"
      else
        die "rank mode expects: procusage rank [cpu|mem] [N]"
      fi
      ;;
    *)
      mode="app"
      app="$1"
      [[ -z "${2:-}" ]] || die "app mode expects: procusage <app>"
      ;;
  esac

  case "$sort_by" in
    cpu|mem|memory) ;;
    *) die "sort must be cpu or mem" ;;
  esac
  is_positive_int "$limit" || die "count must be a positive integer"
}

main() {
  local mode app sort_by limit app_target
  local expected_exec="" names="" expected_base=""

  parse_args "$@"

  if [[ "$mode" == "rank" ]]; then
    print_rank_rows "$sort_by" "$limit"
    return 0
  fi

  app_target="$(find_app_target "$app" 2>/dev/null || true)"
  if [[ -n "$app_target" ]]; then
    expected_exec="${app_target%%$'\t'*}"
    names="${app_target#*$'\t'}"
    expected_base="${expected_exec##*/}"
  else
    names="$app"
  fi

  print_app_rows "$app" "$expected_exec" "$names" "$expected_base"
}

main "$@"
